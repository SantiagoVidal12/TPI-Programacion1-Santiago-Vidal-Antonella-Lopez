# ============================================================
# actualizar.py
# Función: actualizar_pais
# Actualiza población y/o superficie de un país existente.
# Requiere: pedir_texto, buscar_exacto, guardar_paises
# ============================================================

def actualizar_pais(paises: list) -> None:
    """
    Busca un país por nombre exacto y permite modificar
    su población y/o superficie.
    Dejar vacío conserva el valor actual.
    """
    print('='*60)
    print('ACTUALIZAR DATOS DE UN PAIS')
    print('='*60)

    # Busca el país por nombre exacto
    nombre = pedir_texto('Nombre exacto del pais a actualizar: ')
    pais   = buscar_exacto(paises, nombre)

    # Si no existe muestra un error y sale
    if pais is None:
        print(f"Error: no se encontro el pais '{nombre}'.")
        print("Verifique el nombre o use la opcion Buscar primero.")
        print('='*60)
        return

    # Muestra los datos actuales del país encontrado
    print(f"\nDatos actuales de {pais['nombre']}:")
    print(f"  Poblacion  : {pais['poblacion']:,} hab.")
    print(f"  Superficie : {pais['superficie']:,} km2")
    print(f"  Continente : {pais['continente']}")
    print("\n(Presione Enter sin escribir para no modificar el campo)")

    # Pide nueva población — Enter conserva el valor actual
    entrada_pob = input('Nueva poblacion  (Enter para conservar): ').strip()
    if entrada_pob != "":
        try:
            nueva_pob = int(entrada_pob)
            if nueva_pob > 0:
                pais["poblacion"] = nueva_pob
                print(f"  OK Poblacion actualizada a {nueva_pob:,} hab.")
            else:
                print("  Error: valor invalido, poblacion no modificada.")
        except ValueError:
            print("  Error: valor invalido, poblacion no modificada.")

    # Pide nueva superficie — Enter conserva el valor actual
    entrada_sup = input('Nueva superficie (Enter para conservar): ').strip()
    if entrada_sup != "":
        try:
            nueva_sup = int(entrada_sup)
            if nueva_sup > 0:
                pais["superficie"] = nueva_sup
                print(f"  OK Superficie actualizada a {nueva_sup:,} km2.")
            else:
                print("  Error: valor invalido, superficie no modificada.")
        except ValueError:
            print("  Error: valor invalido, superficie no modificada.")

    # Guarda los cambios en el CSV
    guardar_paises(paises)
    print('='*60)
